api_version: "1.0.0"
instrument:
  vendor: "Mock"
  model: "5"
  identifier: "Meter1"
  description: "Mock Voltage Meter"
protocol:
  type: "Custom"
channel_groups:
  - name: analog
    description: "Analog input channels"
    channel_parameter:
      name: channel
      type: int
      min: 1
      max: 8
      description: "Voltage meter channel number (1-8)"
    io_types:
      - name: stream 
        type: array 
        role: input
        description: "Voltage to set"
        unit: "V"
      - name: voltage
        type: float
        role: input
        description: "Measured DC voltage"
        unit: "V"
      - name: sample_rate
        type: int
        role: setting
        description: "Sample rate of the channel"
        unit: "Hz"
      - name: bins
        type: int
        role: setting
        description: "Number of bins to average for each data point"
io: []
commands:
  SET_SAMPLE_RATE:
    template: "SOUR:SAMPle:{analog}:{sample_rate}"
    description: "Set the sample rate"
    parameters:
      - io: sample_rate
    outputs: []
  SET_BINS:
    template: "SOUR:BINS:{analog}:{bins}"
    description: "Set the number of bins to average for each data point"
    parameters:
      - io: bins
    outputs: []
  MEASURE_STREAM:
    template: "MEAS:VOLT:{analog}"
    description: "Set output voltage"
    parameters: []
    outputs: [stream]
  GET_DATAPOINT:
    template: "MEAS:POINt:{analog}"
    description: "Measure a single data point"
    parameters: []
    outputs: [voltage]
  RESET:
    template: "RESET"
    description: "resets the mock instrument"
    parameters: []
    outputs: []
