Version: @PROJECT_VERSION@
Installation Directory: @CMAKE_INSTALL_PREFIX@

Directory Structure:
  @CMAKE_INSTALL_PREFIX@/@INSTALL_BIN_DIR@/          - Executable binaries
  @CMAKE_INSTALL_PREFIX@/@INSTALL_LIB_DIR@/          - Runtime & static libraries
  @CMAKE_INSTALL_PREFIX@/@INSTALL_INCLUDE_DIR@/      - Header files
  @CMAKE_INSTALL_PREFIX@/@INSTALL_CMAKE_DIR@/        - CMake configuration files
  @CMAKE_INSTALL_PREFIX@/@INSTALL_PKGCONFIG_DIR@/    - pkg-config files

Environment Variables to Set:

Linux:
  export PATH="@CMAKE_INSTALL_PREFIX@/bin:$PATH"
  export LD_LIBRARY_PATH="@CMAKE_INSTALL_PREFIX@/lib:$LD_LIBRARY_PATH"
  export PKG_CONFIG_PATH="@CMAKE_INSTALL_PREFIX@/lib/pkgconfig:$PKG_CONFIG_PATH"
  export CMAKE_PREFIX_PATH="@CMAKE_INSTALL_PREFIX@/lib/cmake:$CMAKE_PREFIX_PATH"

Windows (PowerShell):
  $env:PATH = "@CMAKE_INSTALL_PREFIX@\bin;" + $env:PATH
  $env:CMAKE_PREFIX_PATH = "@CMAKE_INSTALL_PREFIX@\lib\cmake;" + $env:CMAKE_PREFIX_PATH

Windows (cmd.exe):
  set PATH=@CMAKE_INSTALL_PREFIX@\bin;%PATH%
  set CMAKE_PREFIX_PATH=@CMAKE_INSTALL_PREFIX@\lib\cmake;%CMAKE_PREFIX_PATH%

