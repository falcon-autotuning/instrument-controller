{
  "name": "instrument-script-server",
  "version-string": "2.0.2",
  "port-version": 26,
  "description": "a modular, process-isolated system for controlling scientific instruments for FAlCon use",
  "builtin-baseline": "e5a1490e1409d175932ef6014519e9ae149ddb7c",
  "dependencies": [
    "vcpkg-cmake",
    "vcpkg-cmake-config",
    "grpc",
    "protobuf",
    "lua",
    "nlohmann-json",
    "spdlog",
    "sol2",
    "cxxopts",
    "yaml-cpp",
    "boost-interprocess",
    "boost-date-time",
    "instrument-data",
    "instrument-log",
    {
      "name": "instrument-call-stack",
      "features": [
        "lua"
      ]
    },
    {
      "name": "instrument-plugin-api",
      "features": [
        "host"
      ]
    }
  ]
}
